<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CineTrack" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/couleur_primaire</item>
        <item name="colorPrimaryVariant">@color/couleur_primaire</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/couleur_secondaire</item>
        <item name="colorSecondaryVariant">@color/couleur_secondaire</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/screen_background</item>
        <item name="android:editTextBackground">@drawable/bg_input_rounded</item>
        <item name="materialButtonStyle">@style/CineTrack.PrimaryButton</item>
        <item name="colorSurface">@color/surface_card</item>
    </style>

    <style name="CineTrack.PrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="backgroundTint">@color/couleur_secondaire</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingLeft">18dp</item>
        <item name="android:paddingRight">18dp</item>
    </style>

    <style name="CineTrack.SecondaryButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">20dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">54dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/surface_card</item>
    </style>
</resources>
